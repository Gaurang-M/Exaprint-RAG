# OpenAI — embeddings
OPENAI_API_KEY=sk-...

# Anthropic — LLM (answer generation)
ANTHROPIC_API_KEY=sk-ant-...

# ChromaDB
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=exaprint_docs

# Models
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# API server
PORT=3000
NODE_ENV=development

# RAG retrieval — number of chunks to retrieve per query
RETRIEVER_K=5
