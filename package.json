{
  "name": "exaprint-rag",
  "version": "1.0.0",
  "description": "RAG system for Exaprint website — internal customer search",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "ingest": "tsx src/cli/ingest.ts",
    "ingest:site": "tsx src/cli/ingest.ts --clear --depth 5 --timeout 30000 --exclude /login /account /panier /carrito /checkout /mi-cuenta --",
    "serve": "tsx src/api/server.ts",
    "serve:watch": "tsx watch src/api/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.0",
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "chromadb": "2.4.6",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "html-to-text": "^9.0.0",
    "jsdom": "^24.0.0",
    "langchain": "^0.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
